---
import Layout from '../layouts/Layout.astro';
import { listPublicFiles } from '../lib/db';

const files = await listPublicFiles(50);

function formatBytes(bytes: number): string {
  if (bytes === 0) return '0 B';
  const units = ['B', 'KB', 'MB', 'GB'];
  const index = Math.floor(Math.log(bytes) / Math.log(1024));
  return `${parseFloat((bytes / Math.pow(1024, index)).toFixed(2))} ${units[index]}`;
}

function formatDate(value: string): string {
  return new Date(value).toLocaleString('en-US', {
    day: '2-digit',
    month: 'short',
    hour: '2-digit',
    minute: '2-digit',
  });
}
---

<Layout title="Discover · openbin">
  <section class="flex flex-1 flex-col gap-4 overflow-hidden p-4 sm:p-6">
    <header class="flex shrink-0 items-center justify-between gap-4 border border-surface-light bg-surface px-4 py-3 shadow-sm">
      <div class="flex min-w-0 items-center gap-3">
        <a href="/">
          <img src="/favicon.svg" alt="" class="h-7 w-7 shrink-0" />
        </a>
        <div class="min-w-0">
          <p class="mb-0.5 text-[10px] font-semibold uppercase tracking-[0.18em] text-primary">Openbin</p>
          <h1 class="text-sm font-medium text-main">Discover</h1>
          <p class="text-xs text-muted">Recent public bins</p>
        </div>
      </div>
      <a href="/" class="h-8 border border-primary bg-primary px-3 py-2 text-xs font-medium text-white transition-colors hover:bg-primary/90">
        Create bin
      </a>
    </header>

    <main class="min-h-0 flex-1 overflow-auto bg-background shadow-sm sm:p-6">
      {files.length > 0 ? (
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {files.map((file) => (
            <a href={`/f/${file.slug}`} class="group border border-surface-light bg-surface p-4 transition-colors hover:border-primary/60 hover:bg-surface-light">
              <div class="mb-4 flex items-start justify-between gap-3">
                <div class="flex min-w-0 items-center gap-2">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center bg-primary/10 text-[10px] font-semibold uppercase text-primary">
                    {file.filename.split('.').pop()?.slice(0, 3) || 'txt'}
                  </span>
                  <h2 class="truncate text-sm font-medium text-main group-hover:text-primary">{file.filename}</h2>
                </div>
                <span class="shrink-0 text-[10px] text-muted">{formatBytes(Number(file.size))}</span>
              </div>
              <div class="flex items-center justify-between gap-2 border-t border-surface-light pt-3 text-xs text-muted">
                <span>{file.author ? `by ${file.author}` : 'anonymous'}</span>
                <span>{formatDate(file.created_at)}</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="flex h-full flex-col items-center justify-center gap-2 text-center">
          <div class="flex h-10 w-10 items-center justify-center border border-surface-light bg-surface text-muted">∅</div>
          <p class="text-sm font-medium text-main">No public bins yet</p>
          <p class="text-xs text-muted">Create a bin without a password to see it here.</p>
        </div>
      )}
    </main>
  </section>
</Layout>
