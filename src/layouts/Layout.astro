---
import '../styles/global.css';

export interface Props {
  title?: string;
}

const { title = 'Openbin: Read, write, share, and inspire.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Lightweight Pastebin/CDN on IPFS" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <script is:inline>
      const savedTheme = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
      document.documentElement.dataset.theme = savedTheme || 'dark';
    </script>
  </head>
  <body class="h-screen flex flex-col bg-background text-main antialiased overflow-hidden">
    <main class="flex-1 flex flex-col min-h-0 overflow-hidden">
      <slot />
    </main>
  </body>
</html>
